# ============================================================
#  MẪU biến môi trường cho deploy. TRÊN VPS:
#    cp .env.example .env   (rồi sửa giá trị bên dưới)
#  File .env thật KHÔNG được commit (đã nằm trong .gitignore).
# ============================================================

# Mật khẩu MySQL — tự đặt 1 chuỗi mạnh, dùng cho cả root DB lẫn backend
DB_PASSWORD=doi-mat-khau-nay-cho-manh

# Địa chỉ frontend (để backend cho phép CORS). Dùng IP VPS, có http://
CORS_ORIGIN=http://167.71.17.113

# JWT — đặt 2 chuỗi ngẫu nhiên, mỗi chuỗi >= 32 ký tự
JWT_ACCESS_SECRET=doi-thanh-chuoi-ngau-nhien-toi-thieu-32-ky-tu
JWT_REFRESH_SECRET=doi-thanh-chuoi-ngau-nhien-khac-toi-thieu-32-ky-tu

# Redis (Upstash) — lấy từ dashboard Upstash của bạn
REDIS_HOST=immortal-jaybird-137879.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary — lấy từ dashboard Cloudinary
CLOUDINARY_CLOUD_NAME=dqbzw0jb2
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Chatbot — Đa nhà cung cấp (Fallback tự động)
# Điền key của ít nhất 1 nhà cung cấp. Nhiều key = dự phòng tốt hơn.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
